# Docker Compose project settings
SKYFI_HTTP_PORT=8080
SKYFI_FRONTEND_PORT=5173
SKYFI_DB_PORT=3306
SKYFI_REDIS_PORT=6379

# Production URLs
APP_URL=https://api.example.com
APP_ISSUER=https://api.example.com
APP_AUDIENCE=https://app.example.com
VITE_API_BASE_URL=/api/v1
CORS_ALLOWED_ORIGINS=https://app.example.com

# Application secrets - replace before any shared environment
JWT_SECRET=replace-with-at-least-32-bytes-of-random-data
MIKROTIK_CREDENTIAL_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key

# MariaDB
MARIADB_DATABASE=skyfi
MARIADB_USER=skyfi
MARIADB_PASSWORD=replace-me
MARIADB_ROOT_PASSWORD=replace-me-root
MARIADB_INNODB_BUFFER_POOL_SIZE=1G
MARIADB_MAX_CONNECTIONS=200

# Redis
REDIS_PASSWORD=replace-me-redis

# PHP-FPM sizing
PHP_FPM_MAX_CHILDREN=40
PHP_FPM_START_SERVERS=8
PHP_FPM_MIN_SPARE_SERVERS=4
PHP_FPM_MAX_SPARE_SERVERS=12
PHP_FPM_MAX_REQUESTS=500

# Worker heartbeat interval
SKYFI_WORKER_INTERVAL_SECONDS=300

# Optional image tags for production compose
SKYFI_NGINX_IMAGE=skyfi/nginx:latest
SKYFI_BACKEND_IMAGE=skyfi/backend:latest
SKYFI_SUPERVISOR_IMAGE=skyfi/supervisor:latest
