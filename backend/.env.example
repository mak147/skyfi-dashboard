APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_ISSUER=https://api.skyfinetworks.com
APP_AUDIENCE=https://app.skyfinetworks.com

# Use a cryptographically random value of at least 32 bytes in every non-local environment.
JWT_SECRET=replace-with-a-high-entropy-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
JWT_SESSION_REFRESH_TTL=28800

DB_DSN=mysql:host=127.0.0.1;port=3306;dbname=skyfi;charset=utf8mb4
DB_USERNAME=skyfi
DB_PASSWORD=secret

CORS_ALLOWED_ORIGINS=http://localhost:5173
REFRESH_COOKIE_NAME=skyfi_refresh_token
REFRESH_COOKIE_PATH=/api/v1/auth
REFRESH_COOKIE_SECURE=false
# Local development only. Keep false in every shared or production environment.
EXPOSE_PASSWORD_RESET_TOKEN=false
LOG_PATH=storage/logs/app.log

# Base64-encoded 32-byte key. Generate with: php -r "echo base64_encode(random_bytes(32)), PHP_EOL;"
MIKROTIK_CREDENTIAL_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
MIKROTIK_API_CONNECT_TIMEOUT_SECONDS=5
MIKROTIK_API_COMMAND_TIMEOUT_SECONDS=10
MIKROTIK_API_MAX_RETRIES=2
MIKROTIK_API_MAX_CONNECTIONS_PER_ROUTER=1
MIKROTIK_API_TLS_VERIFY_PEER=true
# MIKROTIK_API_TLS_CA_FILE=/run/secrets/skyfi-router-ca.pem
