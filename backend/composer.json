{
  "name": "skyfi/skyfi-api",
  "description": "SkyFi Networks ISP Management System REST API",
  "type": "project",
  "require": {
    "php": "^8.2",
    "dompdf/dompdf": "^3.1",
    "phpoffice/phpspreadsheet": "^2.3 || ^3.0 || ^4.0 || ^5.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "SkyFi\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SkyFi\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "check": "php -l public/index.php"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
